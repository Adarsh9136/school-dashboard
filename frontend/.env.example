# Frontend environment (React / CRA)
# Copy to `.env` before running locally and set the value.
# On Vercel: add these under Project Settings → Environment Variables.

# Public URL of your deployed backend (Render/Railway/Fly URL, or your Vercel API URL if using monorepo serverless).
# DO NOT include a trailing slash. All API calls in the code go to `${REACT_APP_BACKEND_URL}/api/...`.
REACT_APP_BACKEND_URL=https://your-backend-domain.example.com
