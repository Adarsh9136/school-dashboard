# Backend environment (Node.js / Express / Mongoose)
# Copy to `.env` before running locally, and set every value.
# On your hosting provider (Render / Railway / Fly / Vercel): add each of these under
# Environment Variables. Never commit the real .env file.

# ── Database ────────────────────────────────────────────────
# MongoDB Atlas connection string (recommended for production)
# Format: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# For local dev with a local MongoDB: mongodb://localhost:27017
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name (schema is created automatically on first write)
DB_NAME=resonance_erp

# ── Auth ────────────────────────────────────────────────────
# JWT signing secret. Use a long random string in production.
# Generate one with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# ── Server ──────────────────────────────────────────────────
# Port the Node server binds to. Render/Railway/Fly usually set this automatically.
PORT=8001

# CORS origins. Comma-separated. Use "*" only for testing. In production, restrict to your Vercel frontend URL.
# Example: https://resonance.vercel.app,https://www.yourschool.edu.in
CORS_ORIGINS=https://your-frontend-domain.vercel.app
